# Copy to backend.hcl (gitignored) and fill in your values, then:
#   terraform init -backend-config=backend.hcl
#
# One-time bootstrap (bucket and lock table must exist before init):
#   aws s3api create-bucket --bucket YOUR_STATE_BUCKET --region us-east-1
#   aws s3api put-bucket-versioning --bucket YOUR_STATE_BUCKET \
#     --versioning-configuration Status=Enabled
#   aws s3api put-public-access-block --bucket YOUR_STATE_BUCKET \
#     --public-access-block-configuration BlockPublicAcls=true,IgnorePublicAcls=true,BlockPublicPolicy=true,RestrictPublicBuckets=true
#   aws dynamodb create-table --table-name YOUR_LOCK_TABLE \
#     --attribute-definitions AttributeName=LockID,AttributeType=S \
#     --key-schema AttributeName=LockID,KeyType=HASH \
#     --billing-mode PAY_PER_REQUEST

bucket         = "YOUR_STATE_BUCKET"
key            = "event-analytics/terraform.tfstate"
region         = "us-east-1"
dynamodb_table = "YOUR_LOCK_TABLE"
encrypt        = true
